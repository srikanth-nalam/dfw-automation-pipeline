<?xml version="1.0" encoding="UTF-8"?>
<workflow xmlns="http://vmware.com/vco/workflow"
         id="com.dfw.automation.bulk-tag-remediation"
         version="2.0.0"
         api-version="6.0.0">
  <display-name>DFW - Bulk Tag Remediation</display-name>
  <description>
    Bulk tag remediation workflow for applying tag corrections to multiple VMs
    in a single coordinated operation. Supports CSV-based input, performs impact
    analysis per VM, applies tags in batches with rate limiting, and generates
    a summary report.

    Triggered by: ServiceNow Bulk Tag Request catalog item via vRO REST trigger.
    Orchestrator: BulkTagOrchestrator
  </description>

  <position x="50" y="50"/>

  <input>
    <param name="correlationId" type="string"/>
    <param name="requestPayload" type="string"/>
    <param name="callbackUrl" type="string"/>
    <param name="callbackToken" type="string"/>
  </input>

  <output>
    <param name="result" type="string"/>
    <param name="status" type="string"/>
    <param name="successCount" type="number"/>
    <param name="failureCount" type="number"/>
  </output>

  <attrib name="config" type="Properties" read-only="false"/>
  <attrib name="vmList" type="Array/string" read-only="false"/>
  <attrib name="batchSize" type="number" read-only="false"/>

  <!-- Import via vRO Client or Aria Automation Assembler -->
  <!-- Action bindings configured during deployment -->
  <!--
    Action References:
      - com.dfw.shared/ConfigLoader
      - com.dfw.shared/Logger
      - com.dfw.shared/CorrelationContext
      - com.dfw.shared/RateLimiter
      - com.dfw.lifecycle/BulkTagOrchestrator
      - com.dfw.lifecycle/ImpactAnalysisAction
      - com.dfw.tags/TagOperations
      - com.dfw.tags/TagCardinalityEnforcer
      - com.dfw.tags/TagPropagationVerifier
      - com.dfw.groups/GroupMembershipVerifier
      - com.dfw.adapters/NsxApiAdapter
      - com.dfw.adapters/SnowPayloadAdapter
  -->
</workflow>
