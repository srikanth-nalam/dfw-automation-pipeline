<?xml version="1.0" encoding="UTF-8"?>
<workflow xmlns="http://vmware.com/vco/workflow"
         id="com.dfw.automation.dayn-decommission"
         version="2.0.0"
         api-version="6.0.0">
  <display-name>DFW - Day N Decommission</display-name>
  <description>
    Day-N decommissioning workflow for VM teardown. Removes NSX-T tags, verifies
    security group removal, archives DFW policy references, cleans up the rule
    registry, and sends the callback result to ServiceNow.

    Triggered by: ServiceNow VM Decommission Request or automated lifecycle
    expiration via vRO REST trigger.
    Orchestrator: DayNOrchestrator
  </description>

  <position x="50" y="50"/>

  <input>
    <param name="correlationId" type="string"/>
    <param name="requestPayload" type="string"/>
    <param name="callbackUrl" type="string"/>
    <param name="callbackToken" type="string"/>
  </input>

  <output>
    <param name="result" type="string"/>
    <param name="status" type="string"/>
  </output>

  <attrib name="config" type="Properties" read-only="false"/>
  <attrib name="existingTags" type="Properties" read-only="false"/>
  <attrib name="associatedRules" type="Array/string" read-only="false"/>

  <!-- Import via vRO Client or Aria Automation Assembler -->
  <!-- Action bindings configured during deployment -->
  <!--
    Action References:
      - com.dfw.shared/ConfigLoader
      - com.dfw.shared/Logger
      - com.dfw.shared/CorrelationContext
      - com.dfw.lifecycle/DayNOrchestrator
      - com.dfw.lifecycle/SagaCoordinator
      - com.dfw.tags/TagOperations
      - com.dfw.groups/GroupMembershipVerifier
      - com.dfw.dfw/RuleRegistry
      - com.dfw.dfw/RuleLifecycleManager
      - com.dfw.adapters/NsxApiAdapter
      - com.dfw.adapters/VcenterApiAdapter
      - com.dfw.adapters/SnowPayloadAdapter
  -->
</workflow>
