<?xml version="1.0" encoding="UTF-8"?>
<workflow xmlns="http://vmware.com/vco/workflow"
         id="com.dfw.automation.day2-tag-update"
         version="2.0.0"
         api-version="6.0.0">
  <display-name>DFW - Day 2 Tag Update</display-name>
  <description>
    Day-2 tag update workflow for existing VMs. Detects changed tags, performs
    impact analysis, applies the updated NSX-T tags, verifies security group
    re-evaluation, and sends the callback result to ServiceNow.

    Triggered by: ServiceNow Tag Update Request catalog item or CMDB business
    rule (cmdbTagSyncRule) via vRO REST trigger.
    Orchestrator: Day2Orchestrator
  </description>

  <position x="50" y="50"/>

  <input>
    <param name="correlationId" type="string"/>
    <param name="requestPayload" type="string"/>
    <param name="callbackUrl" type="string"/>
    <param name="callbackToken" type="string"/>
  </input>

  <output>
    <param name="result" type="string"/>
    <param name="status" type="string"/>
  </output>

  <attrib name="config" type="Properties" read-only="false"/>
  <attrib name="changedTags" type="Properties" read-only="false"/>
  <attrib name="impactReport" type="string" read-only="false"/>

  <!-- Import via vRO Client or Aria Automation Assembler -->
  <!-- Action bindings configured during deployment -->
  <!--
    Action References:
      - com.dfw.shared/ConfigLoader
      - com.dfw.shared/Logger
      - com.dfw.shared/CorrelationContext
      - com.dfw.shared/PayloadValidator
      - com.dfw.lifecycle/Day2Orchestrator
      - com.dfw.lifecycle/ImpactAnalysisAction
      - com.dfw.lifecycle/SagaCoordinator
      - com.dfw.tags/TagOperations
      - com.dfw.tags/TagCardinalityEnforcer
      - com.dfw.tags/TagPropagationVerifier
      - com.dfw.groups/GroupMembershipVerifier
      - com.dfw.groups/GroupReconciler
      - com.dfw.adapters/NsxApiAdapter
      - com.dfw.adapters/SnowPayloadAdapter
  -->
</workflow>
